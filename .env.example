# Snowflake
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=ELT_WH
SNOWFLAKE_DATABASE=ELT_DB
SNOWFLAKE_ROLE=ELT_ROLE

# Reddit API
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=elt-pipeline/1.0

# OpenWeather API
OPENWEATHER_API_KEY=your_api_key

# SaaS PostgreSQL Source
SAAS_DB_HOST=localhost
SAAS_DB_PORT=5432
SAAS_DB_NAME=saas_app
SAAS_DB_USER=readonly_user
SAAS_DB_PASSWORD=your_password

# Slack Alerting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key
AIRFLOW__CORE__LOAD_EXAMPLES=False
